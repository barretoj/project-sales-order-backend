{
  "compilerOptions": {
    "target": "ES2024",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "outDir": "./dist",
    "rootDir": "./",
    "paths": {
      "@models/*": ["./@cds-models/*/index.ts"]
    }
  },
  "include": ["srv"], // Mudança aqui para ser mais abrangente
  "exclude": ["node_modules", "dist"]
}